# warden4w dotfiles — .zshrc
# Managed by warden-dotfiles/install.sh (symlinked). Edit in the repo, not here.

# --- History ---
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt hist_ignore_dups share_history

# --- Completions (native zsh; no oh-my-zsh) ---
autoload -Uz compinit
compinit -d "${XDG_CACHE_HOME:-$HOME/.cache}/zcompdump"
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# --- Plugins (baked into the gold image at a fixed path) ---
ZSH_PLUGIN_DIR=/usr/share/zsh-plugins
[[ -f $ZSH_PLUGIN_DIR/zsh-autosuggestions/zsh-autosuggestions.zsh ]] \
  && source $ZSH_PLUGIN_DIR/zsh-autosuggestions/zsh-autosuggestions.zsh
[[ -f $ZSH_PLUGIN_DIR/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] \
  && source $ZSH_PLUGIN_DIR/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# --- Aliases ---
alias ll='ls -lah --color=auto'
alias gs='git status'
alias vim='nvim'

# --- Prompt (oh-my-posh owns it) ---
if command -v oh-my-posh >/dev/null 2>&1; then
  eval $(oh-my-posh init zsh --config "$HOME/warden/dotfiles/oh-my-posh/warden.omp.json")
fi
